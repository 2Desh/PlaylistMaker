<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/newPlaylistButton"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginTop="@dimen/margin_24dp"
        android:backgroundTint="@color/placeholder_base_color"
        android:fontFamily="@font/ys_display_medium"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="@string/new_playlist_button"
        android:textAllCaps="false"
        android:textColor="@color/playlist_btn_text_color"
        android:textSize="14sp"
        app:cornerRadius="54dp" />

    <ImageView
        android:layout_width="@dimen/placeholder_def_size"
        android:layout_height="@dimen/placeholder_def_size"
        android:layout_marginTop="@dimen/margin_46dp"
        android:contentDescription="@string/no_playlist"
        android:src="@drawable/placeholder_no_results" />

    <TextView
        style="@style/PlaceholderTextStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_16dp"
        android:text="@string/no_playlist"
        android:textAlignment="center" />
</LinearLayout>